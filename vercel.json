{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/migrate.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/migrate",
      "dest": "/api/migrate.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings"
  },
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "python manage.py migrate",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/refresh-nav/",
      "schedule": "0 7 * * *"
    }
  ]
}
