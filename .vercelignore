# Exclude large directories and files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git
.mypy_cache
.pytest_cache
.hypothesis

# Exclude media and large static files
media/
*.pdf
*.zip
*.tar.gz
*.csv
*.xlsx
*.xls

# Exclude development files
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Include only essential static files
!static/css/
!static/js/
!static/images/
