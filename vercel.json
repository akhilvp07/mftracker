{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "api/setup_admin.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/setup-admin",
      "dest": "/api/setup_admin.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "config.settings"
  },
  "installCommand": "pip install -r requirements-vercel.txt",
  "buildCommand": "python manage.py migrate",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/cron/refresh-nav/",
      "schedule": "0 7 * * *"
    }
  ],
  "framework": null
}
